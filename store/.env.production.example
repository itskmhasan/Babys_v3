# Copy this file and update with your production values
# DO NOT commit actual secrets to GitHub - use Render's environment variables instead

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://your-backend-api.onrender.com/v1
NEXT_PUBLIC_API_SOCKET_URL=https://your-backend-api.onrender.com

# Stripe (Payment Gateway)
NEXT_PUBLIC_STRIPE_KEY=pk_live_your_production_stripe_key

# Cloudinary (Image Upload)
NEXT_PUBLIC_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/your_cloud_name/image/upload
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Store Domain
NEXT_PUBLIC_STORE_DOMAIN=https://your-store-domain.onrender.com/

# NextAuth Configuration
NEXTAUTH_URL=https://your-store-domain.onrender.com
NEXTAUTH_SECRET=generate_a_secure_secret_key_here

# Node Environment
NODE_ENV=production
